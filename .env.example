# ============================================================
#  ASSISTANT TELEGRAM — CONFIGURATION CLIENT
#  Copiez ce fichier en .env et remplissez chaque valeur
# ============================================================

# --- TELEGRAM ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# IDs Telegram autorisés (séparés par des virgules). Laisser vide = accès libre.
ALLOWED_TELEGRAM_IDS=

# --- ANTHROPIC (Claude) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6

# --- RECHERCHE WEB (Tavily) ---
TAVILY_API_KEY=your_tavily_api_key_here

# --- LINKEDIN ---
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
# Votre URN de profil LinkedIn (ex: urn:li:person:XXXXXXX)
LINKEDIN_PERSON_URN=urn:li:person:your_id_here

# --- GOOGLE (Calendar + Gmail) ---
# Chemin vers le fichier token OAuth2 généré par scripts/google_auth.py
GOOGLE_TOKEN_PATH=config/google_token.json
# Chemin vers le fichier credentials téléchargé depuis Google Cloud Console
GOOGLE_CREDENTIALS_PATH=config/google_credentials.json
# Adresse email du compte Google utilisé
GOOGLE_USER_EMAIL=your@email.com
# Fuseau horaire (ex: Europe/Paris)
TIMEZONE=Europe/Paris

# --- PERSONNALISATION ASSISTANT ---
ASSISTANT_NAME=Alex
# Langue principale (fr / en)
ASSISTANT_LANGUAGE=fr
# Ton de l'assistant: professional / friendly / casual
ASSISTANT_TONE=friendly
